# Application settings
APP_NAME=mqtt-ingestor
APP_ENV=dev
HTTP_PORT=8080

# MQTT Configuration
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=mqtt-ingestor-1
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=sensores/+/telemetry
MQTT_QOS=1

# Database Configuration
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/iot?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
